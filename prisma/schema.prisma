// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id               Int            @id @default(autoincrement())
  username         String         @db.VarChar(255)
  email            String         @unique @db.VarChar(255)
  passwordHash     String         @map("password_hash") @db.VarChar(255)
  profileImageUrl  String?        @map("profile_image_url") @db.Text
  createdAt        DateTime       @default(now()) @map("created_at")
  
  // Relations
  habitsCreated    Habit[]        @relation("HabitCreator")
  habitMemberships HabitMember[]
  habitLogs        HabitLog[]
  streaks          Streak[]
  notifications    Notification[]
  friendRequestsSent     Friendship[] @relation("Requester")
  friendRequestsReceived Friendship[] @relation("Receiver")

  @@map("users")
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int              @map("requester_id")
  receiverId  Int              @map("receiver_id")
  status      FriendshipStatus @default(PENDING)

  requester   User             @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User             @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@map("friendships")
}

model Habit {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  description String?       @db.Text
  creatorId   Int?          @map("creator_id")
  isGroup     Boolean       @default(false) @map("is_group")
  createdAt   DateTime      @default(now()) @map("created_at")

  creator     User?         @relation("HabitCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  members     HabitMember[]
  logs        HabitLog[]
  streaks     Streak[]
  notifications Notification[]

  @@map("habits")
}

model HabitMember {
  id       Int      @id @default(autoincrement())
  habitId  Int      @map("habit_id")
  userId   Int      @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  habit    Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId])
  @@map("habit_members")
}

model HabitLog {
  id            Int      @id @default(autoincrement())
  habitId       Int      @map("habit_id")
  userId        Int      @map("user_id")
  dateCompleted DateTime @map("date_completed") @db.Date
  proofFileUrl  String?  @map("proof_file_url") @db.Text
  notes         String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  habit         Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habit_logs")
}

model Streak {
  id                Int       @id @default(autoincrement())
  habitId           Int       @map("habit_id")
  userId            Int?      @map("user_id") // Null for group-wide streaks
  currentStreak     Int       @default(0) @map("current_streak")
  longestStreak     Int       @default(0) @map("longest_streak")
  lastCompletedDate DateTime? @map("last_completed_date") @db.Date

  habit             Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId])
  @@map("streaks")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  habitId   Int      @map("habit_id")
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
