generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int            @id @default(autoincrement())
  username         String         @db.VarChar(255)
  email            String         @unique @db.VarChar(255)
  passwordHash     String         @map("password_hash") @db.VarChar(255)
  profileImageUrl  String?        @map("profile_image_url")
  createdAt        DateTime       @default(now()) @map("created_at")
  habitLogs        HabitLog[]
  habitMemberships HabitMember[]
  habitsCreated    Habit[]        @relation("HabitCreator")
  notifications    Notification[]
  streaks          Streak[]

  @@map("users")
}

model Habit {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(255)
  description     String?
  creatorId       Int?            @map("creator_id")
  isGroup         Boolean         @default(false) @map("is_group")
  createdAt       DateTime        @default(now()) @map("created_at")
  frequencyCount  Int             @default(1) @map("frequency_count")
  frequencyPeriod FrequencyPeriod @default(DAY) @map("frequency_period")
  logs            HabitLog[]
  members         HabitMember[]
  creator         User?           @relation("HabitCreator", fields: [creatorId], references: [id])
  notifications   Notification[]
  streaks         Streak[]

  @@map("habits")
}

model HabitMember {
  id       Int              @id @default(autoincrement())
  habitId  Int              @map("habit_id")
  userId   Int              @map("user_id")
  joinedAt DateTime         @default(now()) @map("joined_at")
  status   MembershipStatus @default(ACCEPTED)
  habit    Habit            @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId])
  @@map("habit_members")
}

model HabitLog {
  id            Int      @id @default(autoincrement())
  habitId       Int      @map("habit_id")
  userId        Int      @map("user_id")
  dateCompleted DateTime @map("date_completed") @db.Date
  proofFileUrl  String?  @map("proof_file_url")
  notes         String
  createdAt     DateTime @default(now()) @map("created_at")
  habit         Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habit_logs")
}

model Streak {
  id                Int       @id @default(autoincrement())
  habitId           Int       @map("habit_id")
  userId            Int?      @map("user_id")
  currentStreak     Int       @default(0) @map("current_streak")
  longestStreak     Int       @default(0) @map("longest_streak")
  lastCompletedDate DateTime? @map("last_completed_date") @db.Date
  habit             Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId])
  @@map("streaks")
}

model Notification {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  habitId      Int      @map("habit_id")
  message      String
  proofFileUrl String?  @map("proof_file_url")
  isRead       Boolean  @default(false) @map("is_read")
  createdAt    DateTime @default(now()) @map("created_at")
  habit        Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum MembershipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum FrequencyPeriod {
  DAY
  WEEK
  MONTH
}

enum Frequency {
  DAILY
  WEEKLY
}
